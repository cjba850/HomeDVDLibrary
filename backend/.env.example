# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=dvdlib
DB_PASS=dvdlib_secret
DB_ROOT_PASS=changeme_root
DB_NAME=dvdlibrary

# ── OMDB API key ─────────────────────────────────────────────
# Free key (1000 req/day): https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_key_here

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# See README.md "Google SSO Setup" for full step-by-step instructions.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Public URL of this app — used as the OAuth callback base URL.
# No trailing slash. Must exactly match what you register in Google Console.
APP_URL=http://localhost:3000

# ── Access Control ───────────────────────────────────────────
# Allow ANY user from this Google Workspace domain to sign in.
ALLOWED_DOMAIN=yourdomain.com

# Comma-separated specific email addresses (checked in addition to ALLOWED_DOMAIN).
ALLOWED_EMAILS=

# ── Session ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string
SESSION_MAX_AGE=28800000

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
