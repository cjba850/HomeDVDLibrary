# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=dvdlib
DB_PASS=dvdlib_secret
DB_ROOT_PASS=changeme_root
DB_NAME=dvdlibrary

# ── OMDB API key ─────────────────────────────────────────────
# Free key (1000 req/day): https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_key_here

# ── Authentication ───────────────────────────────────────────
# Set AUTH_ENABLED=false to disable Google SSO entirely.
# Anyone who can reach the server can use the app — no login required.
# Recommended for single-user / private-network deployments only.
# Default: true (Google SSO required)
AUTH_ENABLED=true

# Google OAuth 2.0 credentials (only needed when AUTH_ENABLED=true)
# Create at: https://console.cloud.google.com/
# See README "Google SSO Setup" for full instructions.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Public URL of this app — used as the OAuth callback base.
# No trailing slash. Must exactly match what you register in Google Console.
APP_URL=http://localhost:3000

# ── Access Control (when AUTH_ENABLED=true) ──────────────────
# Allow any user from this Google Workspace domain:
ALLOWED_DOMAIN=yourdomain.com

# And/or specific individual email addresses (comma-separated):
ALLOWED_EMAILS=

# ── Session ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string
SESSION_MAX_AGE=28800000

# Set to 'true' ONLY when served over end-to-end HTTPS (e.g. behind nginx with SSL).
# Leave false for HTTP or if Node sits behind an nginx HTTP→app proxy.
SESSION_COOKIE_SECURE=false

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
